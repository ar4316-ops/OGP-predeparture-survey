      <zones>
        <zone h='100000' id='4' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone forceUpdate='true' h='27273' id='3' type-v2='text' w='91237' x='4430' y='9545'>
            <formatted-text>
              <run bold='true' fontalignment='1' fontsize='21'>Spring 2026 Pre-Departure Survey Analysis</run>
              <run fontalignment='1'>Æ&#10;&#10;</run>
              <run bold='true' fontalignment='1' fontsize='18'><![CDATA[NYU <[Parameters].[Sort (copy)]>]]></run>
            </formatted-text>
            <zone-style>
              <format attr='border-color' value='#000000' />
              <format attr='border-style' value='none' />
              <format attr='border-width' value='0' />
              <format attr='margin' value='4' />
            </zone-style>
          </zone>
          <zone forceUpdate='true' h='62455' id='5' type-v2='text' w='91237' x='4430' y='36818'>
            <formatted-text>
              <run bold='true' fontsize='14'>Introduction</run>
              <run>Æ&#10;&#10;</run>
              <run fontsize='14'>The Pre-Departure Survey aims to help us better understand students’ feelings about their preparation to study away, their expectations, and their concerns, as well as the factors that affected their decision-making about whether and where to study away.</run>
              <run>Æ&#10;&#10;&#10;</run>
              <run fontsize='14'>This report summarizes responses across all study away locations to questions in three areas:</run>
              <run>Æ&#10;&#10;</run>
              <run fontsize='14'>• Deciding to Study Away and Selecting a Location</run>
              <run>Æ&#10;</run>
              <run fontsize='14'>• Preparing to Study Away</run>
              <run>Æ&#10;</run>
              <run fontsize='14'>• Expectations and Goals</run>
              <run>Æ&#10;&#10;</run>
              <run fontsize='14'>This survey was not sent to students in first-year cohorts or students who are returning to the same location for a second consecutive term.</run>
              <run>Æ&#10;&#10;</run>
              <run fontsize='14'>Please reach out to global.planning@nyu.edu with any questions.</run>
            </formatted-text>
            <zone-style>
              <format attr='border-color' value='#000000' />
              <format attr='border-style' value='none' />
              <format attr='border-width' value='0' />
              <format attr='margin' value='4' />
            </zone-style>
          </zone>
          <zone h='98546' id='6' param='horz' type-v2='layout-flow' w='3489' x='941' y='727' />
