      <aliases enabled='yes' />
      <column caption='Overall language %' datatype='real' name='[Calculation_1340383899633004546]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED [Calculation_79938946146930688]: sum(iif([Overall - language (group)] = &apos;Extremely important &amp; Very important&apos;, 1, NULL))}&#13;&#10;/&#13;&#10;{FIXED [Calculation_79938946146930688]: count([__tableau_internal_object_id__].[Fa24PDSresults.csv_95F41786BF93410AA9A2CF1798B32229])}' />
      </column>
      <column caption='Response rate (sort)' datatype='real' name='[Calculation_1959910295037898752]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM({FIXED  [Site]: SUM([Calculation_79938946147373058])/SUM([Calculation_79938946147250177])})' />
      </column>
      <column caption='Prepared cat' datatype='string' name='[Calculation_1959910295041556481]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='if [Resource PDO % (copy)_959266781248069672] &gt;= .85 THEN &apos;H&apos;&#13;&#10;ELSEIF [Resource PDO % (copy)_959266781248069672] &lt; .7 THEN &apos;L&apos;&#13;&#10;ELSE &apos;M&apos;&#13;&#10;END' />
      </column>
      <column caption='SF fit %' datatype='real' name='[Calculation_1959910295044796418]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED [Calculation_79938946146930688]: sum(iif([Why did you choose to study away in Spring versus Fall? (Select up to 2.) - Selected Choice - Better fit with my overall plan t] = &apos;Better fit with my overall plan to complete my degree&apos;, 1, NULL))}&#13;&#10;/&#13;&#10;{FIXED [Calculation_79938946146930688]: count([__tableau_internal_object_id__].[Fa24PDSresults.csv_95F41786BF93410AA9A2CF1798B32229])}' />
      </column>
      <column caption='Location' datatype='string' name='[Calculation_79938946146930688]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Site] = &apos;NYU Abu Dhabi&apos; THEN &apos;Abu Dhabi&apos;&#13;&#10;ELSEIF [Site] = &apos;NYU Accra&apos; THEN &apos;Accra&apos;&#13;&#10;ELSEIF [Site] = &apos;NYU Berlin&apos; THEN &apos;Berlin&apos;&#13;&#10;ELSEIF [Site] = &apos;NYU Buenos Aires&apos; THEN &apos;Buenos Aires&apos; &#13;&#10;ELSEIF [Site] = &apos;NYU Florence&apos; THEN &apos;Florence&apos;&#13;&#10;ELSEIF [Site] = &apos;NYU London&apos; THEN &apos;London&apos;&#13;&#10;ELSEIF [Site] = &apos;NYU Los Angeles&apos; THEN &apos;Los Angeles&apos;&#13;&#10;ELSEIF [Site] = &apos;NYU Madrid&apos; THEN &apos;Madrid&apos;&#13;&#10;ELSEIF [Site] = &apos;NYU New York&apos; THEN &apos;New York&apos;&#13;&#10;ELSEIF [Site] = &apos;NYU Paris&apos; THEN &apos;Paris&apos;&#13;&#10;ELSEIF [Site] = &apos;NYU Prague&apos; THEN &apos;Prague&apos;&#13;&#10;ELSEIF [Site] = &apos;NYU Shanghai&apos; THEN &apos;Shanghai&apos;&#13;&#10;ELSEIF [Site] = &apos;NYU Sydney&apos; THEN &apos;Sydney&apos; &#13;&#10;ELSEIF [Site] = &apos;NYU Washington, DC&apos; THEN &apos;Washington, DC&apos; &#13;&#10;ELSEIF [Site] = &apos;NYU Tel Aviv&apos; THEN &apos;Tel Aviv&apos;&#13;&#10;ELSEIF [Site] = &apos;NYU Tulsa&apos; THEN &apos;Tulsa&apos;&#13;&#10;ELSE [Site]&#13;&#10;END' />
      </column>
      <column caption='Surveyed' datatype='integer' name='[Calculation_79938946147250177]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ INCLUDE [Site]: MIN([Sent])}' />
      </column>
      <column caption='Response count' datatype='integer' name='[Calculation_79938946147373058]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{INCLUDE [Site]: COUNTD([N.Number])}' />
      </column>
      <column caption='Response rate' datatype='real' name='[Calculation_79938946147450883]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF SIZE()&gt;1 THEN &#13;&#10;SUM({FIXED  [Calculation_79938946146930688]: SUM([Calculation_79938946147373058])/SUM([Calculation_79938946147250177])})&#13;&#10;ELSE SUM([Calculation_79938946147373058])/SUM([Calculation_79938946147250177])&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Remaining' datatype='integer' name='[Calculation_79938946147545092]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_79938946147250177]-[Calculation_79938946147373058]' />
      </column>
      <column caption='Low parent' datatype='real' name='[Calculation_79938946193113094]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED [Calculation_79938946146930688]: sum({FIXED [Calculation_79938946146930688], [Which statement best reflects the feelings of your parent(s) or guardian(s) toward your plans to study away?]&#13;&#10;:sum(IF [Which statement best reflects the feelings of your parent(s) or guardian(s) toward your plans to study away?] = &apos;They are pleased that I am studying away and have no major concerns&apos; THEN 1 END)})}&#13;&#10;/&#13;&#10;({FIXED [Calculation_79938946146930688]: COUNT([__tableau_internal_object_id__].[Fa24PDSresults.csv_95F41786BF93410AA9A2CF1798B32229])})' />
      </column>
      <column caption='Sort order' datatype='real' name='[Calculation_79938946440118286]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Ascending&#13;&#10;if [Parameters].[Now we would like to know about how you chose and ranked speciflocations. When choosing a location to study away, how import 18 Parameter] = &apos;1&apos; then [Calculation_79938946147450883]&#13;&#10;&#13;&#10;&#13;&#10;// Descending&#13;&#10;elseif  [Parameters].[Now we would like to know about how you chose and ranked speciflocations. When choosing a location to study away, how import 18 Parameter] = &apos;2&apos; then [Calculation_79938946147450883]*-1&#13;&#10;&#13;&#10;// Alphabetical&#13;&#10;else 0&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Compare' datatype='string' name='[Calculation_79938946806997014]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_79938946146930688] = [Parameters].[Sort (copy)] THEN [Calculation_79938946146930688]&#13;&#10;ELSE &apos;Other locations&apos;&#13;&#10;END' />
      </column>
      <column caption='item marker' datatype='string' name='[Calculation_959266781248978985]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&apos;•&apos;' />
      </column>
      <column datatype='string' name='[City]' role='dimension' semantic-role='[City].[Name]' type='nominal' />
      <column datatype='string' name='[Country (Fall25PDSsent.csv)]' role='dimension' semantic-role='[Country].[ISO3166_2]' type='nominal' />
      <column datatype='string' name='[Country]' role='dimension' semantic-role='[Country].[ISO3166_2]' type='nominal' />
      <column caption='Decide students %' datatype='real' name='[Decide advisor % (copy)_959266781204197403]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED [Calculation_79938946146930688]: sum(iif([In deciding to study away at (Field-Site), did you consult with any of the following people? - Other students] = &apos;Yes, and they were influential in my choice&apos;, 1, NULL))}&#13;&#10;/&#13;&#10;{FIXED [Calculation_79938946146930688]: count([__tableau_internal_object_id__].[Fa24PDSresults.csv_95F41786BF93410AA9A2CF1798B32229])}' />
      </column>
      <column caption='Decide family %' datatype='real' name='[Decide advisor % (copy)_959266781204340764]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED [Calculation_79938946146930688]: sum(iif([In deciding to study away at (Field-Site), did you consult with any of the following people? - Parents, guardians, and family m] = &apos;Yes, and they were influential in my choice&apos;, 1, NULL))}&#13;&#10;/&#13;&#10;{FIXED [Calculation_79938946146930688]: count([__tableau_internal_object_id__].[Fa24PDSresults.csv_95F41786BF93410AA9A2CF1798B32229])}' />
      </column>
      <column caption='Decide site staff %' datatype='real' name='[Decide advisor % (copy)_959266781204471837]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED [Calculation_79938946146930688]: sum(iif([In deciding to study away at (Field-Site), did you consult with any of the following people? - Staff at (Field-Site)] = &apos;Yes, and they were influential in my choice&apos;, 1, NULL))}&#13;&#10;/&#13;&#10;{FIXED [Calculation_79938946146930688]: count([__tableau_internal_object_id__].[Fa24PDSresults.csv_95F41786BF93410AA9A2CF1798B32229])}' />
