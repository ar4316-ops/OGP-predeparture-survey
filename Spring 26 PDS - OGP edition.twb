    <dashboard _.fcp.AccessibleZoneTabOrder.true...enable-sort-zone-taborder='true' name='Cover page'>
      <style>
        <style-rule element='dash-text'>
          <format attr='vertical-align' id='dash-text_5' value='top' />
          <format attr='vertical-align' id='dash-text_47' value='top' />
        </style-rule>
      </style>
      <size maxheight='1100' maxwidth='850' minheight='1100' minwidth='850' preset-index='10' sizing-mode='fixed' />
      <zones>
        <zone h='100000' id='4' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone forceUpdate='true' h='13819' id='3' type-v2='text' w='91237' x='4430' y='9545'>
            <formatted-text>
              <run bold='true' fontalignment='1' fontcolor='#000000' fontsize='21'>Spring 2026 Pre-Departure Survey Analysis</run>
            </formatted-text>
            <zone-style>
              <format attr='border-color' value='#000000' />
              <format attr='border-style' value='none' />
              <format attr='border-width' value='0' />
              <format attr='margin' value='4' />
            </zone-style>
          </zone>
          <zone forceUpdate='true' h='32091' id='5' type-v2='text' w='91237' x='4430' y='23364'>
            <formatted-text>
              <run bold='true' fontcolor='#000000' fontsize='14'>Introduction</run>
              <run>Æ&#10;&#10;</run>
              <run fontcolor='#000000' fontsize='11'>The Pre-Departure Survey aims to help us better understand students’ feelings about their preparation to study away, their expectations, and their concerns, as well as the factors that affected their decision-making about whether and where to study away.</run>
              <run>Æ&#10;&#10;&#10;</run>
              <run fontcolor='#000000' fontsize='11'>This report summarizes responses across all study away locations to questions in three areas:</run>
              <run>Æ&#10;&#10;</run>
              <run fontcolor='#000000' fontsize='11'>• Deciding to Study Away and Selecting a Location</run>
              <run>Æ&#10;</run>
              <run fontcolor='#000000' fontsize='11'>• Preparing to Study Away</run>
              <run>Æ&#10;</run>
              <run fontcolor='#000000' fontsize='11'>• Expectations and Goals</run>
              <run>Æ&#10;</run>
            </formatted-text>
            <zone-style>
              <format attr='border-color' value='#000000' />
              <format attr='border-style' value='none' />
              <format attr='border-width' value='0' />
              <format attr='margin' value='4' />
            </zone-style>
          </zone>
          <zone h='98546' id='6' param='horz' type-v2='layout-flow' w='3489' x='941' y='727' />
          <zone h='98546' id='7' param='horz' type-v2='layout-flow' w='3392' x='95667' y='727' />
          <zone h='43818' id='46' param='vert' type-v2='layout-flow' w='91237' x='4430' y='55455'>
            <zone h='2272' id='48' param='vert' type-v2='layout-flow' w='91237' x='4430' y='55455'>
