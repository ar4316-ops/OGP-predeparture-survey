      <table>
        <view>
          <datasources>
            <datasource caption='Sp26PDSresults.csv+ (Multiple Connections)' name='federated.0wr7i4k1u81dwe128z9w207d57iu' />
          </datasources>
          <datasource-dependencies datasource='federated.0wr7i4k1u81dwe128z9w207d57iu'>
            <column caption='Response rate (sort)' datatype='real' name='[Calculation_1959910295037898752]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM({FIXED  [Site]: SUM([Calculation_79938946147373058])/SUM([Calculation_79938946147250177])})' />
            </column>
            <column caption='Location' datatype='string' name='[Calculation_79938946146930688]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Site] = &apos;NYU Abu Dhabi&apos; THEN &apos;Abu Dhabi&apos;&#13;&#10;ELSEIF [Site] = &apos;NYU Accra&apos; THEN &apos;Accra&apos;&#13;&#10;ELSEIF [Site] = &apos;NYU Berlin&apos; THEN &apos;Berlin&apos;&#13;&#10;ELSEIF [Site] = &apos;NYU Buenos Aires&apos; THEN &apos;Buenos Aires&apos; &#13;&#10;ELSEIF [Site] = &apos;NYU Florence&apos; THEN &apos;Florence&apos;&#13;&#10;ELSEIF [Site] = &apos;NYU London&apos; THEN &apos;London&apos;&#13;&#10;ELSEIF [Site] = &apos;NYU Los Angeles&apos; THEN &apos;Los Angeles&apos;&#13;&#10;ELSEIF [Site] = &apos;NYU Madrid&apos; THEN &apos;Madrid&apos;&#13;&#10;ELSEIF [Site] = &apos;NYU New York&apos; THEN &apos;New York&apos;&#13;&#10;ELSEIF [Site] = &apos;NYU Paris&apos; THEN &apos;Paris&apos;&#13;&#10;ELSEIF [Site] = &apos;NYU Prague&apos; THEN &apos;Prague&apos;&#13;&#10;ELSEIF [Site] = &apos;NYU Shanghai&apos; THEN &apos;Shanghai&apos;&#13;&#10;ELSEIF [Site] = &apos;NYU Sydney&apos; THEN &apos;Sydney&apos; &#13;&#10;ELSEIF [Site] = &apos;NYU Washington, DC&apos; THEN &apos;Washington, DC&apos; &#13;&#10;ELSEIF [Site] = &apos;NYU Tel Aviv&apos; THEN &apos;Tel Aviv&apos;&#13;&#10;ELSEIF [Site] = &apos;NYU Tulsa&apos; THEN &apos;Tulsa&apos;&#13;&#10;ELSE [Site]&#13;&#10;END' />
            </column>
            <column caption='Surveyed' datatype='integer' name='[Calculation_79938946147250177]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ INCLUDE [Site]: MIN([Sent])}' />
            </column>
            <column caption='Response count' datatype='integer' name='[Calculation_79938946147373058]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{INCLUDE [Site]: COUNTD([N.Number])}' />
            </column>
            <column caption='Response rate' datatype='real' name='[Calculation_79938946147450883]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF SIZE()&gt;1 THEN &#13;&#10;SUM({FIXED  [Calculation_79938946146930688]: SUM([Calculation_79938946147373058])/SUM([Calculation_79938946147250177])})&#13;&#10;ELSE SUM([Calculation_79938946147373058])/SUM([Calculation_79938946147250177])&#13;&#10;END'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column datatype='string' name='[N.Number]' role='dimension' type='nominal' />
            <column caption='Response rate (cat)' datatype='string' name='[Response rate (copy)_79938946221649932]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_79938946147450883] &gt;= .75 THEN &apos;H&apos;&#13;&#10;ELSEIF [Calculation_79938946147450883] &lt; .75 AND [Calculation_79938946147450883] &gt;= .5 THEN &apos;HM&apos;&#13;&#10;ELSEIF  [Calculation_79938946147450883] &lt; .25 and [Calculation_79938946147450883] &gt; .1 THEN  &apos;L&apos;&#13;&#10;ELSEIF [Calculation_79938946147450883] &lt;=.1 THEN &apos;LL&apos;&#13;&#10;ELSE &apos;M&apos;&#13;&#10;END'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
